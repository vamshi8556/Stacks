class Solution {
    public ArrayList<Integer> calculateSpan(int[] arr) {
        Stack<Integer> st = new Stack<>();
        ArrayList<Integer> ans = new ArrayList<>();
        for(int i=0 ; i<arr.length ; i++){
            int val = arr[i];
            while(st.size() > 0 && val >= arr[st.peek()]){
                st.pop();
            } 
            int span = -1;
            if(st.size() == 0){
                span = i - (-1);
            }
            else {
                span = i - st.peek();
            }
            st.push(i);
            ans.add(span);
        }
        return ans;
        
    }
}
