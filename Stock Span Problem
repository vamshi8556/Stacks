class Solution {
    static int[] stockSpan(int[] a) {
        Stack<Integer> st = new Stack<>();
        int [] ans = new int [a.length];
        for(int i=0 ; i<a.length ; i++){
            int val = a[i];
            while(st.size() > 0 && val >= a[st.peek()]){
                st.pop();
            }
            int span = -1;
            if(st.size() == 0){
                span = i - (-1);
            }
            else {
                span = i - st.peek();
            }
            st.push(i);
            ans[i] = span;
        }
        return ans;
    }
}
